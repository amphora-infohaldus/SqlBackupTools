# Template for ops/config/secrets.enc.yaml
#
# 1. Copy this file to `secrets.enc.yaml` (same folder)
# 2. Fill in actual values
# 3. Encrypt: `sops --encrypt --in-place ops/config/secrets.enc.yaml`
# 4. Verify: `sops -d ops/config/secrets.enc.yaml` reads it back.
# 5. Commit the ENCRYPTED file. NEVER commit the plain version.
#
# The key naming convention matches the SOPS encrypted_regex in .sops.yaml:
# any field ending in _password, _pw, _secret, _key, or _token is encrypted;
# all others stay in the clear.
#
# Keys here become sqlcmd -v variables, available in any SQL file that
# references $(KeyName). If you add new keys, you can reference them
# from SQL with e.g. `N'$(claude_password)'` inside a DECLARE.

# ----- SQL logins -----
claude_password: "REPLACE_WITH_STRONG_RANDOM"
# sa_password: "only if used; prefer Windows auth"

# ----- Service accounts (post-refactor, Option (b) deferred) -----
# svc_sql2022_password:      ""
# svc_premium2022_password:  ""
# svc_reserv_default_password: ""
# svc_reserv_premium_password: ""

# ----- Backup certificate export password -----
# Used only for rotations / copying the cert to a new instance.
# Same password as was used when the cert was originally exported.
sqlbackupcert_export_password: "REPLACE_WITH_EXPORT_PASSWORD"

# ----- SqlBackupTools.exe runtime secrets (read via --secrets-file) -----
# The .NET restore daemon decrypts this file with `sops -d --output-type json`
# and overlays these keys onto empty CLI fields.
# password:         "SQL login password (if not using Integrated auth)"
# slack_secret:     "xoxb-... — Slack bot token for run-report posts"
# mailgun_api_key:  "key-... — Mailgun v3 API key (from AmphoraPro DB config)"
# mailgun_domain:   "mg.amphora.ee"
# mailgun_from:     "SQL backup <sqlbackup@mg.amphora.ee>"
# mailgun_base_url: "https://api.eu.mailgun.net/v3   (EU region; omit for default)"

# ----- Anything else that's secret -----
# richcopy_shared_key: "..."
